{
  "name": "yildiz-amigurumi-webpage",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "assets:version": "node scripts/bump-asset-version.cjs",
    "format": "prettier --write \"index.html\" \"assets/**/*.{css,js}\"",
    "lint:js": "eslint assets/app.js",
    "lint:css": "stylelint \"assets/styles.css\"",
    "lint": "npm run lint:js && npm run lint:css"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "playwright": "^1.59.1",
    "prettier": "^3.3.3",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1"
  }
}
